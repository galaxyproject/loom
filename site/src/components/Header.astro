---
import { url, links } from '../lib/site';

const nav = [
  { href: url('/') + '#demo', label: 'See it in action' },
  { href: url('/') + '#orbit', label: 'Orbit & Loom' },
  { href: url('/') + '#mcp', label: 'Galaxy MCP' },
  { href: url('/docs'), label: 'Docs' },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={url('/')} class="brand" aria-label="Agentic Science with Galaxy — home">
      <img src={url('/orbit-icon.svg')} alt="" width="30" height="30" class="brand__mark" />
      <span class="brand__text">
        <span class="brand__title">Agentic Science</span>
        <span class="brand__sub">with&nbsp;Galaxy</span>
      </span>
    </a>

    <nav class="nav" aria-label="Primary">
      {nav.map((l) => <a href={l.href} class="nav__link">{l.label}</a>)}
    </nav>

    <div class="header-actions">
      <a href={links.releases} class="header-cta">Get Orbit</a>
      <a href={links.loom} class="icon-btn" aria-label="Loom on GitHub" rel="noopener" target="_blank">
        <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
        </svg>
      </a>
      <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false" id="menu-toggle">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile">
    {nav.map((l) => <a href={l.href} class="mobile-nav__link">{l.label}</a>)}
    <a href={links.releases} class="mobile-nav__link mobile-nav__cta">Get Orbit ↗</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-space) 82%, transparent);
    backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-galaxy-gold) 22%, transparent);
  }
  .site-header__inner {
    max-width: 76rem;
    margin: 0 auto;
    padding: 0.7rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: #fff;
  }
  .brand__mark {
    border-radius: 7px;
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--color-galaxy-gold) 30%, transparent),
      0 4px 12px -4px color-mix(in srgb, var(--color-galaxy-gold) 40%, transparent);
  }
  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand__title {
    font-weight: 700;
    font-size: 1.02rem;
    letter-spacing: -0.01em;
  }
  .brand__sub {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-galaxy-gold) 85%, #fff);
    margin-top: 0.2rem;
  }
  .nav {
    display: flex;
    gap: 1.4rem;
    margin-left: auto;
  }
  .nav__link {
    color: color-mix(in srgb, #fff 78%, transparent);
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 600;
    transition: color 0.15s ease;
    position: relative;
  }
  .nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 100%;
    bottom: -0.4rem;
    height: 2px;
    background: var(--color-galaxy-gold);
    transition: right 0.2s ease;
  }
  .nav__link:hover {
    color: #fff;
  }
  .nav__link:hover::after {
    right: 0;
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .nav + .header-actions {
    margin-left: 0;
  }
  .nav:not(:has(*)) ~ .header-actions,
  .header-actions {
    margin-left: 0;
  }
  .header-cta {
    background: var(--color-galaxy-gold);
    color: var(--color-galaxy-dark);
    font-weight: 700;
    font-size: 0.88rem;
    padding: 0.5rem 0.95rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
    white-space: nowrap;
  }
  .header-cta:hover {
    background: var(--color-galaxy-gold-dark);
    transform: translateY(-1px);
  }
  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 0.5rem;
    color: color-mix(in srgb, #fff 72%, transparent);
    transition: color 0.15s ease, background 0.15s ease;
  }
  .icon-btn:hover {
    color: #fff;
    background: color-mix(in srgb, #fff 8%, transparent);
  }
  .menu-toggle {
    display: none;
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: 0.3rem;
  }
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 0.5rem 1.5rem 1rem;
    gap: 0.2rem;
    border-top: 1px solid color-mix(in srgb, #fff 8%, transparent);
  }
  .mobile-nav.open {
    display: flex;
  }
  .mobile-nav__link {
    color: color-mix(in srgb, #fff 82%, transparent);
    text-decoration: none;
    font-weight: 600;
    padding: 0.6rem 0;
  }
  .mobile-nav__cta {
    color: var(--color-galaxy-gold);
  }

  @media (max-width: 860px) {
    .nav {
      display: none;
    }
    .header-cta {
      display: none;
    }
    .menu-toggle {
      display: inline-flex;
    }
    .header-actions {
      margin-left: auto;
    }
  }
</style>

<script>
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(!!open));
  });
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
    }),
  );
</script>
