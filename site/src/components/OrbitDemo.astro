---
// Self-playing "see it in action" demo: a fake Orbit box that types the user's
// prompt, streams the agent's plan, runs a Galaxy invocation, and writes the
// notebook — across a few switchable, real scenarios. Progressive enhancement:
// scenario 0 is server-rendered in its final state, so no-JS / reduced-motion
// visitors still see a complete transcript; JS clears it and animates.

type Route = 'local' | 'galaxy' | 'hybrid';
interface Step { label: string; route: Route; tool: string }
interface Scenario {
  id: string;
  tab: string;
  blurb: string;
  cwd: string;
  prompt: string;
  reply: string;
  plan: { title: string; tag: Route; steps: Step[] };
  invocation: { label: string; total: number; server: string };
  question: string;
  result: string;
}

const scenarios: Scenario[] = [
  {
    id: 'variant',
    tab: 'Variant calling',
    blurb: 'Call variants across samples, QC local and heavy steps on Galaxy.',
    cwd: '~/chrM-variants',
    prompt: 'Call chrM variants across these 4 samples on Galaxy.',
    reply: "Here's the plan — QC locally, then align and call variants on Galaxy. Approve to run.",
    plan: {
      title: 'chrM Variant Calling',
      tag: 'hybrid',
      steps: [
        { label: 'QC & adapter trim', route: 'local', tool: 'fastp' },
        { label: 'Reference index', route: 'local', tool: 'bwa-index' },
        { label: 'Read alignment', route: 'galaxy', tool: 'bwa-mem2/2.2.1' },
        { label: 'Variant calling', route: 'galaxy', tool: 'bcftools_call' },
      ],
    },
    invocation: { label: 'BWA-MEM alignment (chrM, 4 samples)', total: 4, server: 'usegalaxy.org' },
    question: 'how do mtDNA variants distribute across these tissues?',
    result: 'All 4 samples aligned (mean depth 812×). 27 variants pass filters — 3 are non-synonymous in MT-ND5.',
  },
  {
    id: 'rnaseq',
    tab: 'RNA-seq DE',
    blurb: 'Quantify expression and find differentially expressed genes.',
    cwd: '~/liver-rnaseq',
    prompt: '6 paired-end RNA-seq samples — 3 control, 3 treated. Find the differentially expressed genes.',
    reply: 'Salmon on Galaxy for quantification, then DESeq2 for differential expression. Approve to run.',
    plan: {
      title: 'RNA-seq Differential Expression',
      tag: 'galaxy',
      steps: [
        { label: 'QC & trim', route: 'galaxy', tool: 'fastp' },
        { label: 'Quantify transcripts', route: 'galaxy', tool: 'salmon/1.10.3' },
        { label: 'Differential expression', route: 'galaxy', tool: 'deseq2' },
        { label: 'Summary report', route: 'galaxy', tool: 'multiqc' },
      ],
    },
    invocation: { label: 'Salmon quant (6 samples)', total: 6, server: 'usegalaxy.org' },
    question: 'which genes respond to treatment in liver?',
    result: '1,204 genes DE at padj < 0.05; the up-regulated set is enriched for fatty-acid metabolism (GO:0006631).',
  },
  {
    id: 'qc',
    tab: 'Batch QC',
    blurb: 'QC a whole sequencing run and flag samples to drop.',
    cwd: '~/run-2024-batch',
    prompt: 'QC every FASTQ in ./reads and tell me which samples to drop.',
    reply: "I'll run FastQC per file and aggregate with MultiQC — on Galaxy since it's a big batch. Approve to run.",
    plan: {
      title: 'Batch FASTQ QC',
      tag: 'galaxy',
      steps: [
        { label: 'Per-file QC', route: 'galaxy', tool: 'fastqc' },
        { label: 'Aggregate report', route: 'galaxy', tool: 'multiqc' },
      ],
    },
    invocation: { label: 'FastQC (24 files)', total: 24, server: 'usegalaxy.org' },
    question: 'which samples fail QC and should be dropped?',
    result: '22 / 24 pass. S07 and S19 show >30% adapter content and low per-base quality — recommend dropping both.',
  },
];

const s0 = scenarios[0];
const routeLabel = (r: Route, tool: string) => (r === 'galaxy' ? `galaxy · ${tool}` : r);
---

<div class="demo-shell">
  <div class="demo-tabs" role="tablist" aria-label="Example analyses">
    {
      scenarios.map((s, i) => (
        <button
          class:list={['demo-tab', i === 0 && 'is-active']}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          data-i={i}
        >
          <span class="demo-tab__name">{s.tab}</span>
          <span class="demo-tab__blurb">{s.blurb}</span>
          <span class="demo-tab__progress" aria-hidden="true"></span>
        </button>
      ))
    }
  </div>

  <div class="demo scroll-dark">
    <div class="demo__bar">
      <span class="tl tl--r"></span><span class="tl tl--y"></span><span class="tl tl--g"></span>
      <span class="demo__title">Orbit</span>
      <span class="demo__cwd" id="demoCwd">{s0.cwd}</span>
      <button class="demo__replay" id="demoReplay" type="button" aria-label="Replay">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/></svg>
        <span>Replay</span>
      </button>
    </div>

    <div class="demo__body">
      <section class="demo-chat">
        <div class="pane-hd"><span>Chat</span><span class="pane-hd__icons">▤ ⤓ ▥</span></div>
        <div class="demo-chat__scroll" id="chatStream">
          <!-- SSR final state for scenario 0 -->
          <div class="dmsg dmsg--user"><span class="dmsg__num">1</span><div class="bubble">{s0.prompt}</div></div>
          <div class="dmsg dmsg--bot"><p class="bot-line">{s0.reply}</p>
            <div class="plan-card">
              <div class="plan-card__hd"><strong>{s0.plan.title}</strong><span class={`chip chip-${s0.plan.tag}`}>{s0.plan.tag}</span></div>
              <ul class="plan-steps">
                {s0.plan.steps.map((st) => (
                  <li><span class="ck ok">✓</span>{st.label}<span class={`chip chip-${st.route}`}>{routeLabel(st.route, st.tool)}</span></li>
                ))}
              </ul>
            </div>
          </div>
          <div class="dmsg dmsg--bot"><div class="bubble bubble--result"><span class="result-dot">✓</span>{s0.result}</div></div>
        </div>
        <div class="demo-composer">
          <div class="demo-composer__box"><span id="composerText"></span><span class="demo-cursor" id="composerCursor"></span></div>
          <button class="demo-composer__send" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7z" stroke-linejoin="round" stroke-linecap="round"/></svg>
          </button>
        </div>
      </section>

      <section class="demo-nb">
        <div class="pane-tabs"><span class="tab is-active">Notebook</span><span class="tab">Activity</span><span class="tab">File</span></div>
        <div class="demo-nb__scroll" id="nbStream">
          <h3 class="nb-h1">Plan A: {s0.plan.title} <span class={`chip chip-${s0.plan.tag}`}>{s0.plan.tag}</span></h3>
          <p class="nb-q"><span class="nb-key">Question:</span> {s0.question}</p>
          <div class="nb-h2">Steps</div>
          <ul class="nb-steps">
            {s0.plan.steps.map((st, i) => (
              <li><span class="ck ok">✓</span><span class="strike">{i + 1}. {st.label}</span><span class="nb-route">{st.route === 'galaxy' ? `Galaxy · ${st.tool}` : st.tool}</span></li>
            ))}
          </ul>
          <div class="inv">
            <div class="inv__hd"><span class="inv__label">loom-invocation</span><span class="inv__pill inv__pill--done">completed</span></div>
            <div class="inv__title">{s0.invocation.label}</div>
            <div class="inv__bar"><span class="inv__fill" style="width:100%"></span></div>
            <div class="inv__meta"><span>jobs <b>{s0.invocation.total}</b>/{s0.invocation.total}</span><span class="inv__server">{s0.invocation.server}</span></div>
          </div>
        </div>
      </section>
    </div>

    <div class="demo__foot">
      <span class="foot-run" id="footRun"><span class="hb"></span> ready</span>
      <span class="foot-sep"></span>
      <span class="foot-galaxy"><span class="gx-dot"></span> Galaxy</span>
      <span class="seg"><span class="seg__on">Cloud</span><span class="seg__off">Local</span></span>
      <span class="foot-model">Opus 4.8</span>
      <span class="foot-ctx" id="footTok">notebook.md · git ✓</span>
    </div>
  </div>
</div>

<style>
  .demo-shell {
    --m-base: #2c3143; --m-surface: #343a50; --m-deep: #232838; --m-gold: #ffd700;
    --m-blue: #25537b; --m-text: #f0f2f8; --m-dim: rgba(248, 250, 252, 0.5);
    --m-ok: #4ade80; --m-border: rgba(255, 255, 255, 0.08);
  }

  /* tabs */
  .demo-tabs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.7rem; margin-bottom: 1.1rem; }
  .demo-tab {
    position: relative; text-align: left; cursor: pointer; overflow: hidden;
    background: #fff; border: 1px solid color-mix(in srgb, var(--color-galaxy-primary) 14%, transparent);
    border-radius: 0.6rem; padding: 0.75rem 0.9rem; transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  .demo-tab:hover { transform: translateY(-2px); box-shadow: 0 8px 20px -12px rgba(0,0,0,0.25); }
  .demo-tab__name { display: block; font-weight: 700; color: var(--color-galaxy-dark); font-size: 0.98rem; }
  .demo-tab__blurb { display: block; color: var(--color-galaxy-grey); font-size: 0.82rem; line-height: 1.4; margin-top: 0.15rem; }
  .demo-tab.is-active { border-color: color-mix(in srgb, var(--color-galaxy-gold) 60%, transparent); box-shadow: 0 10px 26px -14px color-mix(in srgb, var(--color-galaxy-gold) 60%, transparent); }
  .demo-tab__progress { position: absolute; left: 0; bottom: 0; height: 3px; width: 0; background: var(--color-galaxy-gold); }
  .demo-tab.is-active .demo-tab__progress { width: var(--p, 0%); transition: width 0.2s linear; }

  /* window */
  .demo {
    container-type: inline-size;
    background: var(--m-base); border: 1px solid rgba(255,255,255,0.1); border-radius: 0.85rem;
    overflow: hidden; color: var(--m-text); font-size: 13px;
    box-shadow: 0 40px 80px -34px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.03); text-align: left;
  }
  .demo__bar { display: flex; align-items: center; gap: 0.5rem; padding: 0.55rem 0.85rem; background: linear-gradient(var(--m-deep), var(--m-base)); border-bottom: 1px solid var(--m-border); }
  .tl { width: 11px; height: 11px; border-radius: 50%; }
  .tl--r { background: #ff5f57; } .tl--y { background: #febc2e; } .tl--g { background: #28c840; }
  .demo__title { font-family: var(--font-mono); color: var(--m-dim); margin-left: 0.4rem; }
  .demo__cwd { font-family: var(--font-mono); color: var(--m-dim); margin-left: auto; font-size: 11px; opacity: 0.75; }
  .demo__replay {
    display: inline-flex; align-items: center; gap: 0.3rem; margin-left: 0.7rem;
    background: color-mix(in srgb, var(--m-gold) 15%, transparent); color: var(--m-gold);
    border: 1px solid color-mix(in srgb, var(--m-gold) 35%, transparent); border-radius: 0.4rem;
    padding: 0.2rem 0.5rem; font-size: 11px; font-family: var(--font-mono); cursor: pointer;
  }
  .demo__replay:hover { background: color-mix(in srgb, var(--m-gold) 25%, transparent); }

  /* fixed height so the box never resizes as messages append (no jump when the
     final result bubble lands); panes flex-fill and scroll internally instead */
  .demo__body { display: grid; grid-template-columns: 1.25fr 1fr; height: 430px; }

  .pane-hd { display: flex; align-items: center; justify-content: space-between; padding: 0.5rem 0.75rem; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--m-dim); border-bottom: 1px solid var(--m-border); }
  .pane-hd__icons { opacity: 0.55; letter-spacing: 0.15em; }

  /* chat */
  .demo-chat { display: flex; flex-direction: column; border-right: 1px solid var(--m-border); min-width: 0; }
  .demo-chat__scroll { flex: 1; min-height: 0; padding: 0.9rem 0.85rem; display: flex; flex-direction: column; gap: 0.8rem; overflow-y: auto; }
  .dmsg { animation: dfade 0.4s ease both; }
  @keyframes dfade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .dmsg--user { display: flex; align-items: flex-start; gap: 0.4rem; justify-content: flex-end; }
  .dmsg__num { font-family: var(--font-mono); font-size: 9px; color: var(--m-dim); background: var(--m-deep); width: 15px; height: 15px; display: grid; place-items: center; border-radius: 4px; margin-top: 0.3rem; }
  .bubble { background: var(--m-blue); color: #fff; padding: 0.45rem 0.65rem; border-radius: 0.6rem 0.6rem 0.2rem 0.6rem; max-width: 86%; line-height: 1.45; }
  .bubble--result { background: color-mix(in srgb, var(--m-ok) 14%, var(--m-deep)); border: 1px solid color-mix(in srgb, var(--m-ok) 30%, transparent); color: var(--m-text); border-radius: 0.6rem; display: flex; gap: 0.45rem; align-items: baseline; }
  .result-dot { color: var(--m-ok); font-weight: 700; }
  .bot-line { margin: 0 0 0.5rem; color: color-mix(in srgb, var(--m-text) 90%, transparent); }

  .plan-card { background: var(--m-deep); border: 1px solid var(--m-border); border-left: 3px solid var(--m-gold); border-radius: 0.5rem; padding: 0.6rem 0.7rem; }
  .plan-card__hd { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
  .plan-steps { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.35rem; }
  .plan-steps li { display: flex; align-items: center; gap: 0.45rem; color: color-mix(in srgb, var(--m-text) 85%, transparent); }

  .chip { display: inline-flex; align-items: center; font-family: var(--font-mono); font-size: 10px; font-weight: 600; padding: 0.1rem 0.4rem; border-radius: 0.35rem; margin-left: auto; white-space: nowrap; }
  .plan-steps .chip, .plan-card__hd .chip { margin-left: 0; }
  .plan-steps li .chip { margin-left: auto; }
  .chip-galaxy { background: color-mix(in srgb, var(--m-blue) 30%, transparent); color: #aecce7; }
  .chip-hybrid { background: color-mix(in srgb, var(--m-gold) 18%, transparent); color: #fff441; }
  .chip-local { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.72); }

  .ck { width: 14px; height: 14px; border-radius: 4px; display: inline-grid; place-items: center; flex: none; font-size: 10px; }
  .ck.ok { background: color-mix(in srgb, var(--m-ok) 22%, transparent); color: var(--m-ok); }
  .ck.run { border: 2px solid color-mix(in srgb, var(--m-gold) 40%, transparent); border-top-color: var(--m-gold); border-radius: 50%; animation: spin 1.1s linear infinite; width: 13px; height: 13px; }

  .tool-card { display: flex; align-items: center; gap: 0.45rem; background: var(--m-surface); border: 1px solid var(--m-border); border-radius: 0.45rem; padding: 0.4rem 0.6rem; font-family: var(--font-mono); font-size: 11px; }
  .tool-card__name { color: var(--m-gold); }
  .tool-card__spin { margin-left: auto; width: 11px; height: 11px; border: 2px solid rgba(255,255,255,0.2); border-top-color: var(--m-gold); border-radius: 50%; animation: spin 1.1s linear infinite; }
  .thinking { display: flex; align-items: center; gap: 0.35rem; color: var(--m-dim); font-size: 11px; }
  .tdot { width: 5px; height: 5px; border-radius: 50%; background: var(--m-gold); opacity: 0.4; animation: tdot 1.4s ease-in-out infinite; }
  .tdot:nth-child(2) { animation-delay: 0.2s; } .tdot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes tdot { 0%,100% { opacity: 0.3; transform: translateY(0); } 50% { opacity: 1; transform: translateY(-2px); } }

  .demo-composer { display: flex; align-items: center; gap: 0.5rem; padding: 0.6rem 0.7rem; border-top: 1px solid var(--m-border); }
  .demo-composer__box { flex: 1; background: var(--m-deep); border: 1px solid var(--m-border); border-radius: 0.55rem; padding: 0.5rem 0.65rem; color: var(--m-text); min-height: 2.1rem; min-width: 0; overflow: hidden; white-space: nowrap; display: flex; align-items: center; }
  .demo-composer__box:empty::before, .demo-composer__box span#composerText:empty::before { color: var(--m-dim); }
  .demo-cursor { display: inline-block; width: 2px; height: 1em; background: var(--m-gold); margin-left: 1px; animation: caret 1s step-end infinite; }
  .demo-cursor.hidden { display: none; }
  .demo-composer__send { width: 30px; height: 30px; flex: none; display: grid; place-items: center; background: var(--m-gold); color: var(--m-base); border: none; border-radius: 0.5rem; }

  /* notebook */
  .demo-nb { display: flex; flex-direction: column; min-width: 0; background: color-mix(in srgb, var(--m-deep) 35%, var(--m-base)); }
  .pane-tabs { display: flex; gap: 0.2rem; padding: 0.35rem 0.5rem 0; border-bottom: 1px solid var(--m-border); }
  .tab { font-size: 11px; padding: 0.4rem 0.55rem; color: var(--m-dim); border-bottom: 2px solid transparent; }
  .tab.is-active { color: #fff; border-bottom-color: var(--m-gold); }
  .demo-nb__scroll { flex: 1; min-height: 0; padding: 0.9rem 0.85rem; overflow-y: auto; }
  .demo-nb__scroll > * { animation: dfade 0.4s ease both; }
  .nb-h1 { margin: 0 0 0.4rem; font-size: 14px; color: #fff; display: flex; align-items: center; gap: 0.4rem; }
  .nb-h1 .chip { margin-left: 0; }
  .nb-q { margin: 0 0 0.75rem; color: color-mix(in srgb, var(--m-text) 78%, transparent); line-height: 1.5; }
  .nb-key { color: var(--m-gold); font-weight: 700; }
  .nb-h2 { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--m-dim); font-weight: 700; margin-bottom: 0.4rem; }
  .nb-steps { list-style: none; margin: 0 0 0.85rem; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .nb-steps li { display: flex; align-items: center; gap: 0.45rem; color: color-mix(in srgb, var(--m-text) 88%, transparent); }
  .nb-steps .strike { text-decoration: line-through; text-decoration-color: var(--m-dim); color: var(--m-dim); }
  .nb-route { font-family: var(--font-mono); font-size: 10px; color: var(--m-dim); margin-left: auto; white-space: nowrap; }

  .inv { background: var(--m-deep); border: 1px solid var(--m-border); border-radius: 0.55rem; padding: 0.65rem 0.7rem; font-family: var(--font-mono); }
  .inv__hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.45rem; }
  .inv__label { font-size: 10px; color: var(--m-dim); }
  .inv__pill { font-size: 9px; padding: 1px 7px; border-radius: 999px; background: color-mix(in srgb, var(--m-gold) 20%, transparent); color: var(--m-gold); }
  .inv__pill--done { background: color-mix(in srgb, var(--m-ok) 20%, transparent); color: var(--m-ok); }
  .inv__title { font-size: 11.5px; color: #fff; margin-bottom: 0.5rem; font-family: var(--font-sans); }
  .inv__bar { height: 6px; border-radius: 999px; background: rgba(255,255,255,0.08); overflow: hidden; position: relative; }
  .inv__fill { display: block; height: 100%; background: linear-gradient(90deg, var(--m-blue), var(--m-gold)); width: 6%; border-radius: 999px; transition: width 1.1s cubic-bezier(0.2,0.8,0.2,1); }
  .inv__meta { display: flex; gap: 0.8rem; margin-top: 0.45rem; font-size: 10px; color: var(--m-dim); }
  .inv__meta b { color: var(--m-text); }
  .inv__server { margin-left: auto; }

  .demo__foot { display: flex; align-items: center; gap: 0.6rem; padding: 0.4rem 0.75rem; background: var(--m-deep); border-top: 1px solid var(--m-border); font-size: 10px; color: var(--m-dim); white-space: nowrap; overflow: hidden; }
  .foot-run { display: flex; align-items: center; gap: 0.35rem; color: color-mix(in srgb, var(--m-text) 80%, transparent); }
  .hb { width: 6px; height: 6px; border-radius: 50%; background: var(--m-gold); animation: tdot 1.3s ease-in-out infinite; }
  .foot-sep { width: 1px; height: 12px; background: var(--m-border); }
  .foot-galaxy { display: flex; align-items: center; gap: 0.3rem; }
  .gx-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--m-ok); box-shadow: 0 0 6px var(--m-ok); }
  .seg { display: inline-flex; border: 1px solid var(--m-border); border-radius: 5px; overflow: hidden; }
  .seg__on { background: color-mix(in srgb, var(--m-gold) 20%, transparent); color: var(--m-gold); padding: 1px 6px; }
  .seg__off { padding: 1px 6px; }
  .foot-ctx { margin-left: auto; font-family: var(--font-mono); }

  @container (max-width: 640px) {
    .demo__body { grid-template-columns: 1fr; height: auto; }
    .demo-nb { border-top: 1px solid var(--m-border); }
    .demo-chat__scroll { flex: none; height: 260px; }
    .demo-nb__scroll { flex: none; height: 300px; }
  }
  @media (max-width: 720px) {
    .demo-tabs { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{ scenarios }}>
  (() => {
    const shell = document.querySelector('.demo-shell');
    if (!shell) return;
    const chat = shell.querySelector('#chatStream');
    const nb = shell.querySelector('#nbStream');
    const cwdEl = shell.querySelector('#demoCwd');
    const composer = shell.querySelector('#composerText');
    const cursor = shell.querySelector('#composerCursor');
    const footRun = shell.querySelector('#footRun');
    const footTok = shell.querySelector('#footTok');
    const tabs = [...shell.querySelectorAll('.demo-tab')];
    const replay = shell.querySelector('#demoReplay');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let token = 0; // cancellation token; bump to abort in-flight sequence
    let current = 0;
    let started = false;

    // Astro scopes styles via a data-astro-cid-* attribute on template nodes.
    // Dynamically created nodes need it too, or the scoped CSS won't match them.
    const cidAttr = [...shell.attributes].find((a) => a.name.startsWith('data-astro-cid-'));
    const cid = cidAttr ? cidAttr.name : null;
    const stampAll = (n) => {
      if (cid && n.setAttribute) {
        n.setAttribute(cid, '');
        n.querySelectorAll && n.querySelectorAll('*').forEach((c) => c.setAttribute(cid, ''));
      }
      return n;
    };
    const sleep = (ms) => new Promise((r) => setTimeout(r, ms));
    const el = (tag, cls, html) => { const n = document.createElement(tag); if (cls) n.className = cls; if (html != null) n.innerHTML = html; return stampAll(n); };
    const setHTML = (node, html) => { node.innerHTML = html; stampAll(node); };
    const scrollDown = (c) => { c.scrollTop = c.scrollHeight; };
    const routeChip = (r, tool) => `<span class="chip chip-${r}">${r === 'galaxy' ? 'galaxy · ' + tool : r}</span>`;
    const esc = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    function setActive(i) {
      tabs.forEach((t, j) => {
        t.classList.toggle('is-active', j === i);
        t.setAttribute('aria-selected', j === i ? 'true' : 'false');
        t.style.setProperty('--p', j === i ? '0%' : '0%');
      });
    }

    async function play(i, myToken) {
      const s = scenarios[i];
      current = i;
      setActive(i);
      chat.innerHTML = '';
      nb.innerHTML = '';
      composer.textContent = '';
      cursor.classList.remove('hidden');
      cwdEl.textContent = s.cwd;
      setHTML(footRun, '<span class="hb"></span> ready');
      footTok.textContent = 'notebook.md · git ✓';

      // 1. type the prompt
      setHTML(footRun, '<span class="hb"></span> typing…');
      for (let c = 0; c < s.prompt.length; c++) {
        if (token !== myToken) return;
        composer.textContent += s.prompt[c];
        await sleep(reduce ? 0 : 22 + Math.random() * 26);
      }
      await sleep(reduce ? 0 : 350);
      if (token !== myToken) return;

      // 2. send -> user bubble
      composer.textContent = '';
      cursor.classList.add('hidden');
      const u = el('div', 'dmsg dmsg--user', `<span class="dmsg__num">1</span><div class="bubble">${esc(s.prompt)}</div>`);
      chat.appendChild(u); scrollDown(chat);
      await sleep(reduce ? 0 : 500);
      if (token !== myToken) return;

      // 3. thinking -> reply
      setHTML(footRun, '<span class="hb"></span> thinking…');
      const think = el('div', 'dmsg dmsg--bot', '<div class="thinking"><span class="tdot"></span><span class="tdot"></span><span class="tdot"></span> drafting a plan…</div>');
      chat.appendChild(think); scrollDown(chat);
      await sleep(reduce ? 0 : 900);
      if (token !== myToken) return;
      think.remove();
      const bot = el('div', 'dmsg dmsg--bot', `<p class="bot-line"></p>`);
      chat.appendChild(bot);
      const botLine = bot.querySelector('.bot-line');
      // word-stream the reply
      const words = s.reply.split(' ');
      for (let w = 0; w < words.length; w++) {
        if (token !== myToken) return;
        botLine.textContent += (w ? ' ' : '') + words[w];
        scrollDown(chat);
        await sleep(reduce ? 0 : 34);
      }

      // 4. plan card
      await sleep(reduce ? 0 : 250);
      if (token !== myToken) return;
      const stepsHtml = s.plan.steps
        .map((st) => `<li><span class="ck ok">✓</span>${esc(st.label)}${routeChip(st.route, st.tool)}</li>`)
        .join('');
      bot.appendChild(el('div', 'plan-card',
        `<div class="plan-card__hd"><strong>${esc(s.plan.title)}</strong><span class="chip chip-${s.plan.tag}">${s.plan.tag}</span></div><ul class="plan-steps">${stepsHtml}</ul>`));
      scrollDown(chat);

      // 5. write the notebook, block by block
      setHTML(footRun, '<span class="hb"></span> writing notebook…');
      const addNb = async (node, d) => { if (token !== myToken) return; nb.appendChild(node); scrollDown(nb); await sleep(reduce ? 0 : d); };
      await addNb(el('h3', 'nb-h1', `Plan A: ${esc(s.plan.title)} <span class="chip chip-${s.plan.tag}">${s.plan.tag}</span>`), 260);
      await addNb(el('p', 'nb-q', `<span class="nb-key">Question:</span> ${esc(s.question)}`), 260);
      await addNb(el('div', 'nb-h2', 'Steps'), 180);
      const nbList = el('ul', 'nb-steps');
      nb.appendChild(nbList);
      for (let si = 0; si < s.plan.steps.length; si++) {
        if (token !== myToken) return;
        const st = s.plan.steps[si];
        const li = el('li', null, `<span class="ck run"></span><span class="nb-label">${si + 1}. ${esc(st.label)}</span><span class="nb-route">${st.route === 'galaxy' ? 'Galaxy · ' + esc(st.tool) : esc(st.tool)}</span>`);
        nbList.appendChild(li); scrollDown(nb);
        await sleep(reduce ? 0 : 320);
      }

      // 6. invocation card + tool card, running
      if (token !== myToken) return;
      const inv = el('div', 'inv',
        `<div class="inv__hd"><span class="inv__label">loom-invocation</span><span class="inv__pill">in_progress</span></div>` +
        `<div class="inv__title">${esc(s.invocation.label)}</div>` +
        `<div class="inv__bar"><span class="inv__fill" style="width:6%"></span></div>` +
        `<div class="inv__meta"><span>jobs <b>0</b>/${s.invocation.total}</span><span class="inv__server">${esc(s.invocation.server)}</span></div>`);
      nb.appendChild(inv); scrollDown(nb);
      const tool = el('div', 'dmsg dmsg--bot', `<div class="tool-card"><span>galaxy · run_workflow</span><span class="tool-card__spin"></span></div>`);
      chat.appendChild(tool); scrollDown(chat);
      setHTML(footRun, '<span class="hb"></span> running on Galaxy…');

      const fill = inv.querySelector('.inv__fill');
      const jobsB = inv.querySelector('.inv__meta b');
      await sleep(reduce ? 0 : 400);
      if (token !== myToken) return;
      // animate jobs
      for (let j = 1; j <= s.invocation.total; j++) {
        if (token !== myToken) return;
        jobsB.textContent = String(j);
        fill.style.width = Math.round((j / s.invocation.total) * 100) + '%';
        footTok.textContent = (2.1 + j * 1.4).toFixed(1) + 'k tok · $' + (0.01 + j * 0.006).toFixed(2);
        await sleep(reduce ? 0 : Math.max(180, 1200 / s.invocation.total));
      }

      // 7. complete: flip steps + invocation
      if (token !== myToken) return;
      const pill = inv.querySelector('.inv__pill');
      pill.classList.add('inv__pill--done');
      pill.textContent = 'completed';
      nbList.querySelectorAll('li').forEach((li) => {
        const ck = li.querySelector('.ck');
        ck.className = 'ck ok';
        ck.textContent = '✓';
        li.querySelector('.nb-label')?.classList.add('strike');
      });
      const spin = tool.querySelector('.tool-card__spin');
      if (spin) { spin.className = 'ck ok'; spin.textContent = '✓'; spin.style.marginLeft = 'auto'; }

      // 8. result
      await sleep(reduce ? 0 : 500);
      if (token !== myToken) return;
      setHTML(footRun, '<span class="hb"></span> done');
      chat.appendChild(el('div', 'dmsg dmsg--bot', `<div class="bubble bubble--result"><span class="result-dot">✓</span>${esc(s.result)}</div>`));
      scrollDown(chat);

      // 9. auto-advance
      const dwell = reduce ? 4000 : 4200;
      const startAt = performance.now();
      const tabEl = tabs[i];
      const tick = () => {
        if (token !== myToken) return;
        const p = Math.min(1, (performance.now() - startAt) / dwell);
        tabEl.style.setProperty('--p', (p * 100).toFixed(1) + '%');
        if (p < 1) requestAnimationFrame(tick);
        else { const next = (i + 1) % scenarios.length; play(next, ++token); }
      };
      if (!reduce) requestAnimationFrame(tick);
      else { await sleep(dwell); if (token === myToken) play((i + 1) % scenarios.length, ++token); }
    }

    function start(i) { token++; play(i, token); }

    // tab clicks
    tabs.forEach((t, i) => t.addEventListener('click', () => start(i)));
    replay?.addEventListener('click', () => start(current));

    // autoplay when scrolled into view
    if (reduce) return; // keep SSR final state; still allow tab clicks to animate
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !started) { started = true; start(0); }
      });
    }, { threshold: 0.4 });
    io.observe(shell);
  })();
</script>
