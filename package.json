{
  "name": "loom",
  "version": "0.1.0",
  "type": "module",
  "description": "AI co-scientist for Galaxy bioinformatics, built on Pi.dev",
  "keywords": [
    "galaxy",
    "bioinformatics",
    "analysis",
    "co-scientist"
  ],
  "author": "Galaxy Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/galaxyproject/pi-galaxy-analyst"
  },
  "bin": {
    "loom": "./bin/loom.js"
  },
  "pi": {
    "extensions": [
      "./extensions/galaxy-analyst"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.3",
    "@sinclair/typebox": "^0.32.0",
    "pi-mcp-adapter": "^2.4.0",
    "uuid": "^9.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate:provenance": "vitest run tests/extension-integration.test.ts -t \"provenance notebook sync\""
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.67.3",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
